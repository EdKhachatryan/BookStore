{
  "extends": ["stylelint-config-standard-scss", "stylelint-config-prettier-scss"],
  "rules": {
    "selector-pseudo-element-no-unknown": [
      true,
      {
        "ignorePseudoElements": ["ng-deep"]
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.component.scss"],
      "rules": {
        "no-empty-source": null
      }
    }
  ]
}
